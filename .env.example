# AI Provider: gemini | openai | anthropic | none
AI_PROVIDER=gemini

# Your API key for the chosen provider
AI_API_KEY=your_api_key_here

# Model override (leave blank for sensible defaults)
# Gemini default:    gemini-2.5-pro
# OpenAI default:    gpt-4o
# Anthropic default: claude-3-5-sonnet-20241022
AI_MODEL=

# Server port (default: 5003)
PORT=5003
